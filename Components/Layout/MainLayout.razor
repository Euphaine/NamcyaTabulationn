@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager NavManager

<style>
    /* Force transparency so the WebGL shader can be seen entirely */
    .main-layout-container {
        background: transparent !important;
        background-image: none !important;
    }

    /* --- Global Approachability (Touch-Friendly UI) --- */
    .btn, .liquid-btn {
        padding: 0.65rem 1.5rem !important;
        font-weight: 600;
        border-radius: 0.5rem !important;
    }
    .form-control, .form-select, .glass-input {
        padding: 0.8rem 1.25rem !important;
        border-radius: 0.5rem !important;
    }

    /* Enhance standard HTML dropdown options to match the dark glass theme */
    select.glass-input option {
        background-color: #0f172a !important; /* Deep Navy */
        color: #ffffff !important;
        padding: 12px;
    }

    /* --- Custom Dropdown Arrow & Recessed Look --- */
    select.glass-input {
        background-color: rgba(0, 0, 0, 0.2) !important; /* Slightly darker depth for dropdowns */
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        background-size: 16px 12px !important;
        background-repeat: no-repeat !important;
        background-position: right 1rem center !important;
        cursor: pointer;
    }

    /* --- Clear Glass Overrides for legacy app.css classes --- */
    .liquid-btn {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05) !important;
    }
    .liquid-btn:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1) !important;
    }
    .icon-glass {
        background: transparent !important;
        background-image: none !important;
        border: 1px solid rgba(255, 255, 255, 0.02) !important;
        box-shadow: none !important;
    }

    /* --- Override legacy app.css glass-panel borders/shadows --- */
    .glass-panel {
        background: transparent !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15) !important;
    }
    .glass-input {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
    }
    .glass-input:focus {
        box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.05) !important;
        border-color: rgba(255, 255, 255, 0.2) !important;
        background-color: rgba(255, 255, 255, 0.1) !important;
    }

    /* --- Glass Switch Toggle Visibility --- */
    .form-check-input.glass-input:checked {
        background-color: #00AEEF !important; /* Vibrant Cyan */
        border-color: #00AEEF !important;
        box-shadow: 0 0 15px rgba(0, 174, 239, 0.6) !important;
    }

    /* --- Force Refraction on ALL Glass Elements Globally --- */
    .glass-panel, .liquid-btn, .glass-card, .icon-glass {
        position: relative;
        z-index: 1;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .glass-panel.hover-zoom:hover, .glass-card:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 
            0 25px 45px rgba(0, 0, 0, 0.3) !important;
        z-index: 10;
    }
    .glass-panel::before, .liquid-btn::before, .glass-card::before, .icon-glass::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        backdrop-filter: blur(12px) saturate(150%);
        -webkit-backdrop-filter: blur(12px) saturate(150%);
        filter: url(#liquid-refraction);
        background: rgba(255, 255, 255, 0.02);
        z-index: -1;
        pointer-events: none;
    }

    .liquid-backdrop {
        backdrop-filter: blur(16px) saturate(200%) contrast(1.1);
        -webkit-backdrop-filter: blur(16px) saturate(200%) contrast(1.1);
        /* Genuine SVG Refraction Distortion */
        filter: url(#liquid-refraction);
        border-radius: inherit;
    }

    /* --- 3D Liquid Glass Tables with Refraction --- */
    .table-responsive {
        overflow: visible !important; /* Prevents tooltips from being clipped by the table container */
    }
    .glass-table {
        border-collapse: separate !important;
        border-spacing: 0 8px !important;
        background: transparent !important;
    }
    .glass-table thead th {
        background: rgba(0, 0, 0, 0.2) !important;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: none !important;
        color: #fff !important;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        padding: 1rem;
    }
    .glass-table thead th:first-child { border-top-left-radius: 1rem; border-bottom-left-radius: 1rem; }
    .glass-table thead th:last-child { border-top-right-radius: 1rem; border-bottom-right-radius: 1rem; }
    
    .glass-table thead {
        position: relative;
        z-index: 1;
    }
    .glass-table tbody {
        position: relative;
        z-index: 10; /* Forces the body (and tooltips) to render ABOVE the blurred table header */
    }
    .glass-table tbody tr {
        background: rgba(255, 255, 255, 0.02) !important;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05) !important;
    }
    .glass-table tbody tr:hover {
        transform: scale(1.02);
        background: rgba(255, 255, 255, 0.05) !important;
        box-shadow: 
            0 15px 35px rgba(0, 0, 0, 0.2) !important;
        position: relative;
        z-index: 9999;
    }
    .glass-table td { 
        border: none !important; 
        background: transparent !important; 
        padding: 1rem !important; 
        vertical-align: middle; 
        position: relative;
        z-index: 1;
    }
    /* Apply refraction safely to table cells without distorting text */
    .glass-table tbody td::before {
        content: '';
        position: absolute;
        inset: 0;
        backdrop-filter: blur(10px) saturate(150%);
        -webkit-backdrop-filter: blur(10px) saturate(150%);
        z-index: -1;
        pointer-events: none;
    }
    .glass-table tbody td:first-child { border-top-left-radius: 1rem; border-bottom-left-radius: 1rem; }
    .glass-table tbody td:first-child::before { border-top-left-radius: 1rem; border-bottom-left-radius: 1rem; }
    .glass-table tbody td:last-child { border-top-right-radius: 1rem; border-bottom-right-radius: 1rem; }
    .glass-table tbody td:last-child::before { border-top-right-radius: 1rem; border-bottom-right-radius: 1rem; }

    /* --- Judge Dashboard Specific Glass Styles --- */
    .contestant-list-item {
        background: transparent !important;
        color: #f8f9fa !important;
        border-color: rgba(255, 255, 255, 0.1) !important;
        padding: 1rem 1.5rem;
        transition: all 0.2s ease-in-out;
        position: relative;
        z-index: 1;
    }
    .contestant-list-item::before {
        content: '';
        position: absolute;
        inset: 0;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        z-index: -1;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
    }
    .contestant-list-item:hover { background: rgba(255, 255, 255, 0.1) !important; transform: translateX(5px); }
    .contestant-list-item:hover::before { opacity: 1; }
    .contestant-list-item.active { background: rgba(255, 255, 255, 0.1) !important; border-left: 4px solid #00AEEF; transform: translateX(0); box-shadow: inset 5px 0 15px rgba(0,0,0,0.2); }
    .contestant-list-item.active::before { opacity: 1; }
    .contestant-list-item .bi-check-circle-fill { opacity: 0.8; }

    /* --- Global Morph Page Transition --- */
    .page-transition {
        animation: morphPage 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        transform-origin: top center;
        will-change: transform, opacity, filter;
    }
    @@keyframes morphPage {
        0% {
            opacity: 0;
            transform: scale(0.96) translateY(15px);
            filter: blur(8px);
        }
        100% {
            opacity: 1;
            transform: scale(1) translateY(0);
            filter: blur(0px);
        }
    }

    /* --- Formal Document Print Styles --- */
    @@media print {
        @@page { size: auto; margin: 0.75in; }
        html, body, .main-layout-container, .main-content {
            background: #ffffff !important;
            color: #000000 !important;
            font-size: 12pt !important;
        }
        #shader-bg-container, svg[aria-hidden="true"] {
            display: none !important;
        }
        * {
            text-shadow: none !important;
            box-shadow: none !important;
            filter: none !important;
            backdrop-filter: none !important;
            -webkit-backdrop-filter: none !important;
            transition: none !important;
            animation: none !important;
        }
        .glass-panel, .glass-card {
            border: none !important;
            padding: 0 !important;
            background: transparent !important;
        }
        /* Formal Table Styling */
        .glass-table {
            border-collapse: collapse !important;
            border-spacing: 0 !important;
            width: 100% !important;
            margin-top: 1rem !important;
        }
        .glass-table th, .glass-table td {
            border: 1px solid #000000 !important;
            color: #000000 !important;
            background: transparent !important;
            padding: 10px !important;
        }
        .glass-table thead th {
            background-color: #f2f2f2 !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-weight: bold !important;
            text-transform: uppercase !important;
            border-bottom: 2px solid #000000 !important;
        }
        .glass-table thead th:first-child, .glass-table thead th:last-child,
        .glass-table tbody td:first-child, .glass-table tbody td:last-child {
            border-radius: 0 !important;
        }
        .text-white, .text-white-50 {
            color: #000000 !important;
        }
        .badge {
            color: #000000 !important;
            background: transparent !important;
            border: none !important;
            font-size: 11pt !important;
            font-weight: bold !important;
            padding: 0 !important;
        }
    }

    /* --- Glassmorphism Blazor Error UI --- */
    #blazor-error-ui {
        background: rgba(15, 23, 42, 0.95) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.5) !important;
        padding: 1rem 1.5rem !important;
        z-index: 9999 !important;
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
    }
    #blazor-error-ui .reload { color: #00AEEF !important; font-weight: bold; text-decoration: none; margin-left: 1rem; }
    #blazor-error-ui .reload:hover { text-decoration: underline; }
    #blazor-error-ui .dismiss { color: #fff !important; opacity: 0.5; cursor: pointer; transition: opacity 0.2s; }
    #blazor-error-ui .dismiss:hover { opacity: 1; }
</style>

<div class="d-flex main-layout-container min-vh-100">
    <!-- The WebGL Shader Background Container -->
    <div id="shader-bg-container" class="position-fixed w-100 h-100 top-0 start-0" style="z-index: -2;"></div>

    <!-- Main Content Area -->
    <main class="flex-grow-1 d-flex flex-column main-content">
        <NavMenu />

        <article class="px-4 pb-5 page-transition" @key="NavManager.Uri">
            @Body
        </article>
    </main>
</div>

<!-- Genuine SVG Refraction Filter -->
<svg style="position: absolute; width: 0; height: 0; pointer-events: none;" aria-hidden="true">
    <defs>
        <filter id="liquid-refraction" color-interpolation-filters="sRGB">
            <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="1" seed="1" result="turbulence" />
            <feGaussianBlur in="turbulence" stdDeviation="2" result="blurredNoise" />
            <feDisplacementMap in="SourceGraphic" in2="blurredNoise" scale="12" xChannelSelector="R" yChannelSelector="B" result="displaced" />
        </filter>
    </defs>
</svg>

<div id="blazor-error-ui" data-nosnippet="true">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initShaderBackground", "shader-bg-container");
        }
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
