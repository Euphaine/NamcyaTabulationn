﻿﻿﻿@using NamcyaTabulation.Services
@implements IDisposable
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager

<div class="w-100 d-flex justify-content-center d-print-none sticky-top mt-3 mb-3 px-3" style="z-index: 1050;">
    <nav class="navbar dynamic-island-nav @(isExpanded ? "expanded shadow-lg" : "shadow")" @onclick="ToggleNav">
        <div class="position-absolute w-100 h-100 top-0 start-0 liquid-backdrop" style="z-index: -1; border-radius: inherit;"></div>
        
        <div class="island-header w-100 d-flex align-items-center justify-content-between" style="z-index: 1;">
            <!-- Invisible spacer on the left to perfectly balance the right icon -->
            <div style="width: 24px;"></div>
            
            <a class="navbar-brand fw-bold mb-0 text-white m-0 d-flex align-items-center justify-content-center" href="/" @onclick:stopPropagation="true">
                <img src="/images/namcya_logo.png" alt="Logo" class="island-logo" />
                <span class="island-text @(isExpanded ? "show" : "")">NAMCYA Tabulation</span>
            </a>
            
            <div class="text-white-50 d-flex align-items-center justify-content-center toggle-icon @(isExpanded ? "rotate" : "")" style="width: 24px;">
                <i class="bi bi-chevron-down fs-5"></i>
            </div>
        </div>

        <div class="nav-links-wrapper @(isExpanded ? "show" : "")" @onclick:stopPropagation="true">
            <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 pt-2 border-top border-light border-opacity-10 w-100">
                @if (AuthService.CurrentOrganizer == null)
                {
                    <NavLink class="nav-pill-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-box-arrow-in-right icon-gradient-purple me-1"></i> Login
                    </NavLink>
                }
                else
                {
                    <NavLink class="nav-pill-link" href="home">
                        <i class="bi bi-house-door icon-gradient-core me-1"></i> Home
                    </NavLink>
                }

                <NavLink class="nav-pill-link" href="judge">
                    <i class="bi bi-person-badge-fill icon-gradient-blue me-1"></i> Judge
                </NavLink>
                <NavLink class="nav-pill-link" href="scoreboard">
                    <i class="bi bi-display icon-gradient-amber me-1"></i> Scoreboard
                </NavLink>
                <NavLink class="nav-pill-link" href="leaderboard">
                    <i class="bi bi-globe icon-gradient-green me-1"></i> Leaderboard
                </NavLink>

                @if (AuthService.CurrentOrganizer != null)
                {
                    <div class="vr bg-white opacity-25 d-none d-md-block mx-1"></div>
                    <NavLink class="nav-pill-link" href="admin-panel">
                        <i class="bi bi-gear-fill icon-gradient-core me-1"></i> Admin Hub
                    </NavLink>
                }
            </div>
        </div>
    </nav>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .dynamic-island-nav {
        background: rgba(20, 20, 25, 0.9) padding-box,
                    linear-gradient(135deg, #4285F4, #9B51E0, #EA4335, #FBBC05) border-box !important;
        backdrop-filter: blur(24px) saturate(200%);
        -webkit-backdrop-filter: blur(24px) saturate(200%);
        border: 2px solid transparent !important;
        box-shadow: 
            0 15px 35px rgba(0, 0, 0, 0.8),
            -30px 0 50px rgba(66, 133, 244, 0.5),
            30px 0 50px rgba(155, 81, 224, 0.5),
            0 30px 50px rgba(234, 67, 53, 0.4),
            inset 0 2px 5px rgba(255, 255, 255, 0.2) !important;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        
        /* --- The True Capsule Shape --- */
        width: 180px; /* Slightly wider to comfortably hold the logo */
        max-height: 48px;
        border-radius: 50px !important;
        padding: 0 1rem; /* Slightly less padding to give the logo more room */
        
        position: relative;
        overflow: hidden; /* Essential to cleanly hide dropdown items when collapsed */
        animation: dynamicIslandTop 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .dynamic-island-nav.expanded {
        width: 100%;
        max-width: 700px;
        max-height: 500px; /* Expands to fit all links */
        border-radius: 28px !important;
        padding-bottom: 1.5rem !important;
        cursor: default;
    }
    .island-header {
        height: 48px;
        min-height: 48px;
        flex-shrink: 0;
    }
    .island-logo {
        height: 28px;
        max-width: 100px; /* Stops the rectangular logo from breaking the capsule bounds */
        object-fit: contain; /* Scales the image perfectly without distortion */
        transition: all 0.4s ease;
    }
    .island-text {
        font-size: 1.05rem;
        font-weight: 600;
        white-space: nowrap;
        color: #ffffff !important;
        opacity: 0;
        max-width: 0;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .island-text.show {
        opacity: 1;
        max-width: 200px;
        margin-left: 0.6rem;
    }
    .dynamic-island-nav:hover:not(.expanded) {
        transform: scale(1.05) translateY(-2px);
        box-shadow: 
            0 20px 45px rgba(0, 0, 0, 0.9),
            -40px 0 70px rgba(66, 133, 244, 0.6),
            40px 0 70px rgba(155, 81, 224, 0.6),
            0 40px 70px rgba(234, 67, 53, 0.5),
            inset 0 2px 5px rgba(255, 255, 255, 0.3) !important;
    }
    .nav-pill-link {
        color: rgba(255, 255, 255, 0.75) !important;
        padding: 0.4rem 1rem;
        border-radius: 50rem;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        white-space: nowrap;
    }
    .nav-pill-link:hover {
        background-color: rgba(255, 255, 255, 0.15);
        color: #ffffff !important;
        transform: translateY(-2px);
    }
    .nav-pill-link.active {
        background-color: rgba(255, 255, 255, 0.25);
        color: #fff !important;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
    }
    
    /* Smooth Expansion Transitions */
    .nav-links-wrapper {
        opacity: 0;
        width: 100%;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }
    .nav-links-wrapper.show {
        opacity: 1;
        transition-delay: 0.2s; /* Waits for the capsule to expand before showing links */
        pointer-events: auto;
    }
    .toggle-icon {
        transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .toggle-icon.rotate {
        transform: rotate(180deg);
    }
    
    @@keyframes dynamicIslandTop {
        0% { transform: translateY(-30px) scale(0.9); opacity: 0; }
        100% { transform: translateY(0) scale(1); opacity: 1; }
    }
</style>

@code {
    private bool isExpanded = false;

    private void ToggleNav()
    {
        isExpanded = !isExpanded;
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        isExpanded = false; // Auto-close when navigating
        StateHasChanged();
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}