﻿﻿﻿﻿﻿﻿﻿<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark">
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["NamcyaTabulation.styles.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="@Assets["images/namcya_logo.png"]" />
    
    <style>
        html {
            font-size: 20px !important; /* Globally scales up the entire UI */
            background-color: #05080f !important; /* Dark space fallback */
            color-scheme: dark; /* Forces the browser engine to use Dark Mode autofill and scrollbars */
        }
        body {
            background-color: transparent !important; 
        }
        /* Prevent the Blazor Reconnect Modal from flashing bright white */
        #components-reconnect-modal {
            background-color: rgba(5, 8, 15, 0.95) !important;
            color: white !important;
        }
    </style>
    
    <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
</head>

<body>
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.downloadFileFromText = (fileName, content, contentType = 'text/csv;charset=utf-8;') => {
            const blob = new Blob([content], { type: contentType });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        // Optimized Cursor Spotlight Tracker
        // Uses requestAnimationFrame to prevent layout thrashing and ensure zero-lag performance
        document.addEventListener("mousemove", (e) => {
            requestAnimationFrame(() => {
                document.documentElement.style.setProperty('--mouse-x', `${e.clientX}px`);
                document.documentElement.style.setProperty('--mouse-y', `${e.clientY}px`);
            });
        });
    </script>
</body>

</html>
