@page "/admin-panel"
@using NamcyaTabulation.Services
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager

<PageTitle>Admin Panel</PageTitle>

@if (AuthService.CurrentOrganizer != null)
{

    <div class="container mt-4 fade-in">
        <!-- Padayaw 2026 Hero Banner -->
        <div class="glass-panel mb-5 p-2 text-center shadow-sm">
            <img src="/images/display_banner.png" alt="NAMCYA Padayaw 2026" class="img-fluid w-100" style="border-radius: 1.25rem;" />
        </div>

        <div class="text-center mb-5">
            <h1 class="fw-bold text-white" style="letter-spacing: -1px; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Admin Hub</h1>
            <p class="text-white-50 fs-5">Manage events, judges, and contestants gracefully.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 position-relative glass-panel hover-zoom bg-transparent border-0">
                    <div class="card-body text-center p-4">
                        <div class="icon-glass"><i class="bi bi-calendar-event text-primary" style="font-size: 2.5rem;"></i></div>
                        <h5 class="fw-bold text-white">Events</h5>
                        <p class="text-white-50 text-sm mb-0">Create and edit Main Events and their Sub-Events.</p>
                        <a href="/admin/events" class="stretched-link"></a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 position-relative glass-panel hover-zoom bg-transparent border-0">
                    <div class="card-body text-center p-4">
                        <div class="icon-glass"><i class="bi bi-tags text-info" style="font-size: 2.5rem;"></i></div>
                        <h5 class="fw-bold text-white">Categories & Criteria</h5>
                        <p class="text-white-50 text-sm mb-0">Set up scoring criteria and categories for contestants.</p>
                        <a href="/admin/categories-criteria" class="stretched-link"></a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 position-relative glass-panel hover-zoom bg-transparent border-0">
                    <div class="card-body text-center p-4">
                        <div class="icon-glass"><i class="bi bi-person-badge text-success" style="font-size: 2.5rem;"></i></div>
                        <h5 class="fw-bold text-white">Manage Judges</h5>
                        <p class="text-white-50 text-sm mb-0">Register judges, assign them to sub-events, and generate PINs.</p>
                        <a href="/admin/judges" class="stretched-link"></a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 position-relative glass-panel hover-zoom bg-transparent border-0">
                    <div class="card-body text-center p-4">
                        <div class="icon-glass"><i class="bi bi-people text-secondary" style="font-size: 2.5rem;"></i></div>
                        <h5 class="fw-bold text-white">Manage Contestants</h5>
                        <p class="text-white-50 text-sm mb-0">Register contestants and assign them to categories.</p>
                        <a href="/admin/contestants" class="stretched-link"></a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 position-relative glass-panel hover-zoom bg-transparent border-0">
                    <div class="card-body text-center p-4">
                        <div class="icon-glass"><i class="bi bi-sliders text-warning" style="font-size: 2.5rem;"></i></div>
                        <h5 class="fw-bold text-white">System Settings</h5>
                        <p class="text-white-50 text-sm mb-0">Configure global tabulation variables and tie-breaker rules.</p>
                        <a href="/settings" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null) 
        {
            NavManager.NavigateTo("/");
        }
    }
}