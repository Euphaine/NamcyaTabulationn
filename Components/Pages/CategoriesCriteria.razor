@page "/admin/categories-criteria"
@using Microsoft.AspNetCore.Components.Web
@using System.Linq
@using Microsoft.EntityFrameworkCore
@using NamcyaTabulation.Data
@using NamcyaTabulation.Models
@using NamcyaTabulation.Services
@inject AppDbContext DbContext
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Manage Categories & Criteria</PageTitle>

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Categories & Criteria</h2>
        <a href="/admin-panel" class="btn btn-outline-light fw-bold"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>

    <!-- Glass Selection Panel -->
    <div class="glass-panel p-4 mb-5 rounded-4 shadow-sm hover-zoom">
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label text-white-50 fs-6">Select Main Event</label>
                <select class="form-select glass-input fs-5 py-3 text-white" @onchange="OnEventChanged">
                    <option value="0">-- Select Event --</option>
                    @foreach (var ev in Events)
                    {
                        <option value="@ev.Id">@ev.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label text-white-50 fs-6">Select Sub-Event</label>
                <select class="form-select glass-input fs-5 py-3 text-white" @onchange="OnSubEventChanged" disabled="@(SelectedEvent == null)">
                    <option value="0">-- Select Sub-Event --</option>
                    @foreach (var sub in SubEvents)
                    {
                        <option value="@sub.Id">@sub.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (SelectedSubEvent != null)
    {
        <div class="row g-4">
            <!-- Categories Panel -->
            <div class="col-lg-5">
                <div class="glass-panel p-4 h-100 d-flex flex-column hover-zoom">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold text-white mb-0" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><i class="bi bi-tags-fill me-2"></i> Categories</h4>
                        <button class="btn btn-sm liquid-btn text-white fw-bold shadow-sm" @onclick="() => showCategoryModal = true">
                            <i class="bi bi-plus-lg me-1"></i> Add
                        </button>
                    </div>
                    
                    <hr class="border-light border-opacity-10 mt-0 mb-4" />
                    
                    @if (!Categories.Any())
                    {
                        <div class="text-white-50 text-center p-4 bg-black bg-opacity-25 rounded-4 border border-light border-opacity-10 mt-2">
                            No categories added yet.
                        </div>
                    }
                    <div class="d-flex flex-column gap-3 flex-grow-1">
                        @foreach (var cat in Categories)
                        {
                            <div class="bg-white bg-opacity-10 border border-light border-opacity-10 rounded-3 p-3 d-flex justify-content-between align-items-center shadow-sm transition-all" style="backdrop-filter: blur(5px);">
                                <strong class="text-white fs-5" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@cat.Name</strong>
                                <button class="btn btn-sm text-danger bg-transparent border-0" @onclick="() => DeleteCategory(cat)" title="Delete Category"><i class="bi bi-trash fs-4"></i></button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Criteria Panel -->
            <div class="col-lg-7">
                <div class="glass-panel p-4 h-100 d-flex flex-column hover-zoom">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <h4 class="fw-bold text-white mb-0" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><i class="bi bi-list-check me-2"></i> Criteria</h4>
                            <span class="badge @(Criteria.Sum(c => c.MaxScore) == 100 ? "bg-success bg-opacity-75" : "bg-warning text-dark") fs-6 shadow-sm px-3 py-2 rounded-pill">Total: @Criteria.Sum(c => c.MaxScore)%</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm text-info fw-bold bg-transparent border-0" @onclick="() => showImportModal = true" title="Clone from another Sub-Event">
                                <i class="bi bi-box-arrow-in-down fs-3"></i>
                            </button>
                            <button class="btn btn-sm liquid-btn text-white fw-bold shadow-sm" @onclick="() => showCriterionModal = true">
                                <i class="bi bi-plus-lg me-1"></i> Add
                            </button>
                        </div>
                    </div>
                    
                    <hr class="border-light border-opacity-10 mt-0 mb-4" />
                    
                    @if (!Criteria.Any())
                    {
                        <div class="text-white-50 text-center p-4 bg-black bg-opacity-25 rounded-4 border border-light border-opacity-10 mt-2">
                            No criteria defined yet. Click the import button or add manually.
                        </div>
                    }
                    <div class="d-flex flex-column gap-3 flex-grow-1">
                        @foreach (var crit in Criteria)
                        {
                            <div class="bg-white bg-opacity-10 border border-light border-opacity-10 rounded-3 p-3 d-flex justify-content-between align-items-center shadow-sm transition-all" style="backdrop-filter: blur(5px);">
                                <strong class="text-white fs-5" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@crit.Name</strong>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge bg-white bg-opacity-25 text-white fs-6 px-3 py-2 border border-light border-opacity-10 shadow-sm rounded-3">Max: @crit.MaxScore</span>
                                    <button class="btn btn-sm text-danger bg-transparent border-0 p-0" @onclick="() => DeleteCriterion(crit)" title="Delete Criterion"><i class="bi bi-trash fs-4"></i></button>
                                </div>
                            </div>
                        }
                    </div>
                    
                    @if (Criteria.Sum(c => c.MaxScore) != 100 && Criteria.Any())
                    {
                        <div class="alert bg-warning bg-opacity-25 text-white border-0 py-3 mt-4 mb-0 d-flex align-items-center rounded-4 fade-in">
                            <i class="bi bi-exclamation-triangle-fill fs-3 me-3 text-warning"></i> 
                            <div>
                                <h6 class="mb-0 fw-bold">Warning: Score Mismatch</h6>
                                <small class="text-white-50">Total max score is currently @Criteria.Sum(c => c.MaxScore). For a standard grading system, it should perfectly total 100.</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Modals -->
    @if (showCategoryModal)
    {
        <div class="glass-modal-overlay" @onclick="CloseModals">
            <div class="glass-modal p-4 p-md-5" @onclick="() => {}" @onclick:stopPropagation="true">
                <h3 class="text-white fw-bold mb-4">Add New Category</h3>
                <form @onsubmit="SaveCategory" @onsubmit:preventDefault="true">
                    <div class="mb-5">
                        <label class="form-label text-white-50 fs-6">Category Name</label>
                        <input type="text" class="form-control glass-input fs-5 text-white py-3" @bind="newCategory.Name" placeholder="e.g., Solo Performance" required autofocus />
                    </div>
                    <div class="d-flex justify-content-end gap-3 mt-4 pt-2 border-top border-light border-opacity-10">
                        <button type="button" class="btn btn-outline-light px-4 fw-bold" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn liquid-btn px-5 fw-bold text-white">Save</button>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (showCriterionModal)
    {
        <div class="glass-modal-overlay" @onclick="CloseModals">
            <div class="glass-modal p-4 p-md-5" @onclick="() => {}" @onclick:stopPropagation="true">
                <h3 class="text-white fw-bold mb-4">Add Criterion</h3>
                <form @onsubmit="SaveCriterion" @onsubmit:preventDefault="true">
                    <div class="mb-4">
                        <label class="form-label text-white-50 fs-6">Criterion Name</label>
                        <input type="text" class="form-control glass-input fs-5 text-white py-3" @bind="newCriterion.Name" placeholder="e.g., Musicality" required autofocus />
                    </div>
                    <div class="mb-5">
                        <label class="form-label text-white-50 fs-6">Max Score (%)</label>
                        <input type="number" class="form-control glass-input fs-5 text-white py-3" @bind="newCriterion.MaxScore" placeholder="e.g., 40" min="1" step="0.1" required />
                    </div>
                    <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top border-light border-opacity-10">
                        <button type="button" class="btn btn-outline-light px-4 fw-bold" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn liquid-btn px-5 fw-bold text-white">Save</button>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (showImportModal)
    {
        <div class="glass-modal-overlay" @onclick="CloseModals">
            <div class="glass-modal p-4 p-md-5" @onclick="() => {}" @onclick:stopPropagation="true">
                <h3 class="text-white fw-bold mb-4">Import Criteria</h3>
                <div class="mb-5">
                    <label class="form-label text-white-50 fs-6">Select Source Sub-Event</label>
                    <select class="form-select glass-input fs-5 text-white py-3" @bind="importSubEventId">
                        <option value="0">-- Select Source --</option>
                        @foreach (var ev in Events)
                        {
                            <optgroup label="@ev.Name" style="background: #0f172a; color: #fff;">
                                @foreach (var sub in AllSubEvents.Where(s => s.EventId == ev.Id && s.Id != (SelectedSubEvent?.Id ?? -1)))
                                {
                                    <option value="@sub.Id" style="background: #1e293b; color: #fff;">@sub.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
                <div class="d-flex justify-content-end gap-3 mt-4 pt-2 border-top border-light border-opacity-10">
                    <button type="button" class="btn btn-outline-light px-4 fw-bold" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn liquid-btn px-5 fw-bold text-white" @onclick="ImportCriteria" disabled="@(importSubEventId == 0)">Clone</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Event> Events = new();
    private List<SubEvent> AllSubEvents = new();
    private List<SubEvent> SubEvents = new();
    private List<Category> Categories = new();
    private List<Criterion> Criteria = new();

    private Event? SelectedEvent;
    private SubEvent? SelectedSubEvent;
    
    private Category newCategory = new();
    private Criterion newCriterion = new();

    private int importSubEventId = 0;

    private bool showCategoryModal = false;
    private bool showCriterionModal = false;
    private bool showImportModal = false;

    private void CloseModals()
    {
        showCategoryModal = false;
        showCriterionModal = false;
        showImportModal = false;
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        Events = await DbContext.Events.ToListAsync();
        AllSubEvents = await DbContext.SubEvents.ToListAsync();
    }

    private async Task OnEventChanged(ChangeEventArgs e)
    {
        SelectedSubEvent = null;
        Categories.Clear();
        Criteria.Clear();

        if (int.TryParse(e.Value?.ToString(), out int eventId) && eventId > 0)
        {
            SelectedEvent = Events.FirstOrDefault(ev => ev.Id == eventId);
            SubEvents = AllSubEvents.Where(s => s.EventId == eventId).ToList();
        }
        else
        {
            SelectedEvent = null;
            SubEvents.Clear();
        }
    }

    private async Task OnSubEventChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int subId) && subId > 0)
        {
            SelectedSubEvent = SubEvents.FirstOrDefault(s => s.Id == subId);
            await LoadSubEventData();
        }
        else
        {
            SelectedSubEvent = null;
            Categories.Clear();
            Criteria.Clear();
        }
    }

    private async Task LoadSubEventData()
    {
        if (SelectedSubEvent != null)
        {
            Categories = await DbContext.Categories.Where(c => c.SubEventId == SelectedSubEvent.Id).ToListAsync();
            Criteria = await DbContext.Criteria.Where(c => c.SubEventId == SelectedSubEvent.Id).ToListAsync();
            importSubEventId = 0; // Reset import dropdown
        }
    }

    private async Task SaveCategory()
    {
        if (SelectedSubEvent == null || string.IsNullOrWhiteSpace(newCategory.Name)) return;
        
        newCategory.SubEventId = SelectedSubEvent.Id;
        DbContext.Categories.Add(newCategory);
        await DbContext.SaveChangesAsync();
        
        newCategory = new Category();
        CloseModals();
        await LoadSubEventData();
    }

    private async Task DeleteCategory(Category cat)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the category '{cat.Name}'?");
        if (confirmed)
        {
            DbContext.Categories.Remove(cat);
            await DbContext.SaveChangesAsync();
            await LoadSubEventData();
        }
    }

    private async Task SaveCriterion()
    {
        if (SelectedSubEvent == null || string.IsNullOrWhiteSpace(newCriterion.Name)) return;

        newCriterion.SubEventId = SelectedSubEvent.Id;
        DbContext.Criteria.Add(newCriterion);
        await DbContext.SaveChangesAsync();
        
        newCriterion = new Criterion();
        CloseModals();
        await LoadSubEventData();
    }

    private async Task DeleteCriterion(Criterion crit)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the criterion '{crit.Name}'? This deletes all scores submitted for it.");
        if (confirmed)
        {
            DbContext.Criteria.Remove(crit);
            await DbContext.SaveChangesAsync();
            await LoadSubEventData();
        }
    }

    // --- Import Criteria Logic (Approach 2) ---
    private async Task ImportCriteria()
    {
        if (SelectedSubEvent == null || importSubEventId == 0) return;

        // Fetch criteria from the source Sub-Event
        var sourceCriteria = await DbContext.Criteria.Where(c => c.SubEventId == importSubEventId).ToListAsync();

        if (!sourceCriteria.Any())
        {
            await JS.InvokeVoidAsync("alert", "The selected Sub-Event has no criteria to clone!");
            return;
        }

        // Clone each criterion into the current Sub-Event
        foreach (var sc in sourceCriteria)
        {
            DbContext.Criteria.Add(new Criterion
            {
                Name = sc.Name,
                MaxScore = sc.MaxScore,
                SubEventId = SelectedSubEvent.Id
            });
        }

        await DbContext.SaveChangesAsync();
        await LoadSubEventData();
        CloseModals();
        await JS.InvokeVoidAsync("alert", "Criteria cloned successfully! You can now freely adjust their Max Scores.");
    }
}