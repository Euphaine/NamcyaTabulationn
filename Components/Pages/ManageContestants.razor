@page "/admin/contestants"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using NamcyaTabulation.Data
@using NamcyaTabulation.Models
@using NamcyaTabulation.Services
@inject AppDbContext DbContext
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Manage Contestants</PageTitle>

<div class="container mt-4 fade-in">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="letter-spacing: -0.5px;">Manage Contestants</h2>
        <p class="text-muted">Select an event to add or remove participants.</p>
    </div>

    <!-- Cascading Selection Card -->
    <div class="glass-card mb-5 p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase ms-2">Event</label>
                    <select class="form-select minimal-input" @onchange="OnEventChanged">
                        <option value="0">-- Select Event --</option>
                        @foreach (var ev in Events)
                        {
                            <option value="@ev.Id">@ev.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase ms-2">Sub-Event</label>
                    <select class="form-select minimal-input" @onchange="OnSubEventChanged" disabled="@(SelectedEvent == null)">
                        <option value="0">-- Select Sub-Event --</option>
                        @foreach (var sub in SubEvents)
                        {
                            <option value="@sub.Id">@sub.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase ms-2">Category</label>
                    <select class="form-select minimal-input" @onchange="OnCategoryChanged" disabled="@(SelectedSubEvent == null)">
                        <option value="0">-- Select Category --</option>
                        @foreach (var cat in Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
            </div>
    </div>

    @if (SelectedCategory != null)
    {
        <div class="glass-card overflow-hidden">
            <div class="bg-primary text-white p-4">
                <h4 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i> @SelectedCategory.Name</h4>
                <p class="mb-0 text-white-50 small mt-1">Add or remove contestants below</p>
            </div>
            <div class="p-4">
                <form @onsubmit="SaveContestant" class="mb-4 d-flex gap-2">
                    <input type="text" class="form-control minimal-input" placeholder="Type Contestant / Group Name..." @bind="newContestant.Name" list="existingContestants" required autocomplete="off" />
                    <button type="submit" class="btn btn-primary minimal-btn px-4 shadow-sm">
                        <i class="bi bi-plus-circle me-1"></i> Add
                    </button>
                </form>
                
                <datalist id="existingContestants">
                    @foreach (var name in ExistingContestantNames)
                    {
                        <option value="@name"></option>
                    }
                </datalist>
                
                <div class="table-responsive">
                    <table class="table table-hover table-borderless align-middle mb-0">
                        <thead class="border-bottom">
                            <tr>
                                <th class="text-muted small fw-bold text-uppercase pb-3">Contestant Name</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Contestants.Any())
                            {
                                <tr>
                                    <td colspan="2" class="text-muted text-center py-5 fs-5">No contestants registered for this category yet.</td>
                                </tr>
                            }
                            @foreach (var contestant in Contestants)
                            {
                                <tr class="border-bottom">
                                    <td class="fw-bold fs-5 py-3 text-dark">@contestant.Name</td>
                                    <td class="text-end">
                                        <button class="btn btn-light text-danger rounded-circle shadow-sm" style="width: 40px; height: 40px;" @onclick="() => DeleteContestant(contestant)" title="Remove Contestant">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Event> Events = new();
    private List<SubEvent> AllSubEvents = new();
    private List<SubEvent> SubEvents = new();
    private List<Category> AllCategories = new();
    private List<Category> Categories = new();
    private List<Contestant> Contestants = new();
    private List<string> ExistingContestantNames = new();

    private Event? SelectedEvent;
    private SubEvent? SelectedSubEvent;
    private Category? SelectedCategory;
    
    private Contestant newContestant = new();

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        Events = await DbContext.Events.ToListAsync();
        AllSubEvents = await DbContext.SubEvents.ToListAsync();
        AllCategories = await DbContext.Categories.ToListAsync();
        await LoadExistingNames();
    }

    private void OnEventChanged(ChangeEventArgs e)
    {
        SelectedSubEvent = null; SelectedCategory = null;
        SubEvents.Clear(); Categories.Clear(); Contestants.Clear();

        if (int.TryParse(e.Value?.ToString(), out int eventId) && eventId > 0)
        {
            SelectedEvent = Events.FirstOrDefault(ev => ev.Id == eventId);
            SubEvents = AllSubEvents.Where(s => s.EventId == eventId).ToList();
        }
        else { SelectedEvent = null; }
    }

    private void OnSubEventChanged(ChangeEventArgs e)
    {
        SelectedCategory = null; Categories.Clear(); Contestants.Clear();

        if (int.TryParse(e.Value?.ToString(), out int subId) && subId > 0)
        {
            SelectedSubEvent = SubEvents.FirstOrDefault(s => s.Id == subId);
            Categories = AllCategories.Where(c => c.SubEventId == subId).ToList();
        }
        else { SelectedSubEvent = null; }
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int catId) && catId > 0)
        {
            SelectedCategory = Categories.FirstOrDefault(c => c.Id == catId);
            await LoadContestants();
        }
        else { SelectedCategory = null; Contestants.Clear(); }
    }

    private async Task LoadContestants()
    {
        if (SelectedCategory != null) { Contestants = await DbContext.Contestants.Where(c => c.CategoryId == SelectedCategory.Id).OrderBy(c => c.Name).ToListAsync(); }
    }

    private async Task LoadExistingNames()
    {
        ExistingContestantNames = await DbContext.Contestants.Select(c => c.Name).Distinct().OrderBy(n => n).ToListAsync();
    }

    private async Task SaveContestant()
    {
        if (SelectedCategory == null || string.IsNullOrWhiteSpace(newContestant.Name)) return;
        newContestant.CategoryId = SelectedCategory.Id;
        DbContext.Contestants.Add(newContestant); await DbContext.SaveChangesAsync();
        newContestant = new Contestant(); await LoadContestants(); await LoadExistingNames();
    }

    private async Task DeleteContestant(Contestant contestant)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to remove '{contestant.Name}'? This will also delete any scores submitted for them.");
        if (confirmed) { DbContext.Contestants.Remove(contestant); await DbContext.SaveChangesAsync(); await LoadContestants(); }
    }
}