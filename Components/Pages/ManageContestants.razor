@page "/admin/contestants"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using NamcyaTabulation.Data
@using NamcyaTabulation.Models
@using NamcyaTabulation.Services
@inject AppDbContext DbContext
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Manage Contestants</PageTitle>

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-bold text-white mb-0" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Manage Contestants</h2>
            @if (SelectedCategory != null)
            {
                <span class="badge bg-white bg-opacity-25 border border-light border-opacity-10 text-white px-3 py-2 rounded-pill shadow-sm fs-6">@Contestants.Count Total</span>
            }
        </div>
        <a href="/admin-panel" class="btn btn-outline-light fw-bold shadow-sm d-none d-sm-inline-block"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>

    <!-- Cascading Selection Card -->
    <div class="glass-panel p-4 mb-4 rounded-4 shadow-sm hover-zoom">
        <div class="row g-4 mb-3">
            <div class="col-md-6">
                <label class="form-label text-white-50 fs-6 fw-bold mb-2"><i class="bi bi-calendar-event me-2"></i>Main Event</label>
                <select class="form-select glass-input fs-5 py-3 text-white fw-bold shadow-sm" @onchange="OnEventChanged">
                    <option value="0">-- Select Event --</option>
                    @foreach (var ev in Events)
                    {
                        <option value="@ev.Id">@ev.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label text-white-50 fs-6 fw-bold mb-2"><i class="bi bi-diagram-3 me-2"></i>Sub-Event</label>
                <select class="form-select glass-input fs-5 py-3 text-white fw-bold shadow-sm" @onchange="OnSubEventChanged" disabled="@(SelectedEvent == null)">
                    <option value="0">-- Select Sub-Event --</option>
                    @foreach (var sub in SubEvents)
                    {
                        <option value="@sub.Id">@sub.Name</option>
                    }
                </select>
            </div>
        </div>
        
        @if (SelectedSubEvent != null)
        {
            if (Categories.Any())
            {
                <div class="mt-4 pt-4 border-top border-light border-opacity-10 fade-in">
                    <label class="form-label text-white-50 fs-6 fw-bold mb-3"><i class="bi bi-tags-fill me-2"></i>Categories</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var cat in Categories)
                        {
                            <button class="btn @(SelectedCategory?.Id == cat.Id ? "liquid-btn text-white shadow" : "glass-input text-white-50") fw-bold px-4 py-2" style="border-radius: 50rem !important;" 
                                    @onclick="() => SelectCategory(cat)">
                                @cat.Name
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="mt-4 pt-4 border-top border-light border-opacity-10 fade-in">
                    <div class="alert bg-black bg-opacity-25 text-white-50 border border-light border-opacity-10 rounded-4 mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i> No categories found for this sub-event.
                    </div>
                </div>
            }
        }
    </div>

    @if (SelectedCategory != null)
    {
        <div class="glass-panel p-4 rounded-4 shadow-sm hover-zoom mb-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold text-white mb-0" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><i class="bi bi-people-fill me-2"></i> Contestant Roster</h4>
                <button class="btn liquid-btn text-white fw-bold shadow-sm" @onclick="OpenAddModal">
                    <i class="bi bi-person-plus-fill me-1"></i> Add Contestant
                </button>
            </div>
            
            <hr class="border-light border-opacity-10 mt-0 mb-4" />
            
            @if (!Contestants.Any())
            {
                <div class="text-white-50 text-center p-5 bg-black bg-opacity-25 rounded-4 border border-light border-opacity-10 mt-2">
                    <i class="bi bi-person-slash fs-1 d-block mb-3"></i>
                    <h5 class="fw-bold">No Contestants Yet</h5>
                    <p class="mb-0">Click the button above to register contestants to this category.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var contestant in Contestants)
                    {
                        <div class="bg-white bg-opacity-10 border border-light border-opacity-10 rounded-4 p-3 d-flex justify-content-between align-items-center shadow-sm transition-all hover-zoom" style="backdrop-filter: blur(5px);">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-black bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center border border-white border-opacity-10 shadow-sm" style="width: 48px; height: 48px;">
                                    <i class="bi bi-person-fill text-white fs-4"></i>
                                </div>
                                <strong class="text-white fs-5" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@contestant.Name</strong>
                            </div>
                            <button class="btn btn-sm text-danger bg-transparent border-0 p-2" @onclick="() => DeleteContestant(contestant)" title="Remove Contestant">
                                <i class="bi bi-trash fs-4"></i>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
    
    <!-- Add Contestant Modal -->
    @if (showModal)
    {
        <div class="glass-modal-overlay" @onclick="CloseModal">
            <div class="glass-modal p-4 p-md-5" @onclick="() => {}" @onclick:stopPropagation="true">
                <h3 class="text-white fw-bold mb-4">Add Contestant to @SelectedCategory?.Name</h3>
                <form @onsubmit="SaveContestant" @onsubmit:preventDefault="true">
                    @if (AvailableExistingNames.Any())
                    {
                        <div class="mb-4">
                            <label class="form-label text-white-50 fs-6 fw-bold mb-2"><i class="bi bi-search me-2"></i>Select Existing Contestant</label>
                            <select class="form-select glass-input fs-5 text-white py-3 shadow-sm" @onchange="OnExistingContestantSelected">
                                <option value="">-- Choose to auto-fill --</option>
                                @foreach (var name in AvailableExistingNames)
                                {
                                    <option value="@name">@name</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex align-items-center mb-4">
                            <hr class="flex-grow-1 border-light border-opacity-25" />
                            <span class="mx-3 text-white-50 fw-bold small">OR ADD NEW</span>
                            <hr class="flex-grow-1 border-light border-opacity-25" />
                        </div>
                    }

                    <div class="mb-5">
                        <label class="form-label text-white-50 fs-6 fw-bold mb-2"><i class="bi bi-person-badge me-2"></i>Contestant Name</label>
                        <input type="text" class="form-control glass-input fs-5 text-white py-3 shadow-sm" placeholder="Type name..." @bind="newContestant.Name" required autocomplete="off" autofocus />
                    </div>
                    
                    <div class="d-flex justify-content-end gap-3 pt-4 border-top border-light border-opacity-10 mt-4">
                        <button type="button" class="btn btn-outline-light px-4 fw-bold" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn liquid-btn px-5 fw-bold text-white">Save Contestant</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@code {
    private List<Event> Events = new();
    private List<SubEvent> AllSubEvents = new();
    private List<SubEvent> SubEvents = new();
    private List<Category> AllCategories = new();
    private List<Category> Categories = new();
    private List<Contestant> Contestants = new();
    private List<string> ExistingContestantNames = new();

    private Event? SelectedEvent;
    private SubEvent? SelectedSubEvent;
    private Category? SelectedCategory;
    
    private Contestant newContestant = new();

    private bool showModal = false;

    // Filters out contestants who are already in the currently selected category
    private IEnumerable<string> AvailableExistingNames => ExistingContestantNames.Where(n => !Contestants.Any(c => c.Name.Equals(n, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        Events = await DbContext.Events.ToListAsync();
        AllSubEvents = await DbContext.SubEvents.ToListAsync();
        AllCategories = await DbContext.Categories.ToListAsync();
        await LoadExistingNames();
    }

    private void OnEventChanged(ChangeEventArgs e)
    {
        SelectedSubEvent = null; SelectedCategory = null;
        SubEvents.Clear(); Categories.Clear(); Contestants.Clear();

        if (int.TryParse(e.Value?.ToString(), out int eventId) && eventId > 0)
        {
            SelectedEvent = Events.FirstOrDefault(ev => ev.Id == eventId);
            SubEvents = AllSubEvents.Where(s => s.EventId == eventId).ToList();
        }
        else { SelectedEvent = null; }
    }

    private void OnSubEventChanged(ChangeEventArgs e)
    {
        SelectedCategory = null; Categories.Clear(); Contestants.Clear();

        if (int.TryParse(e.Value?.ToString(), out int subId) && subId > 0)
        {
            SelectedSubEvent = SubEvents.FirstOrDefault(s => s.Id == subId);
            Categories = AllCategories.Where(c => c.SubEventId == subId).ToList();
        }
        else { SelectedSubEvent = null; }
    }

    private async Task SelectCategory(Category cat)
    {
        SelectedCategory = cat;
        await LoadContestants();
    }

    private async Task LoadContestants()
    {
        if (SelectedCategory != null) { Contestants = await DbContext.Contestants.Where(c => c.CategoryId == SelectedCategory.Id).OrderBy(c => c.Name).ToListAsync(); }
    }

    private async Task LoadExistingNames()
    {
        ExistingContestantNames = await DbContext.Contestants.Select(c => c.Name).Distinct().OrderBy(n => n).ToListAsync();
    }

    private void OpenAddModal()
    {
        newContestant = new Contestant();
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void OnExistingContestantSelected(ChangeEventArgs e)
    {
        var selectedName = e.Value?.ToString();
        if (selectedName != null)
        {
            newContestant.Name = selectedName;
        }
    }

    private async Task SaveContestant()
    {
        if (SelectedCategory == null || string.IsNullOrWhiteSpace(newContestant.Name)) return;
        newContestant.CategoryId = SelectedCategory.Id;
        DbContext.Contestants.Add(newContestant); await DbContext.SaveChangesAsync();
        newContestant = new Contestant(); 
        showModal = false;
        await LoadContestants(); 
        await LoadExistingNames();
    }

    private async Task DeleteContestant(Contestant contestant)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to remove '{contestant.Name}'? This will also delete any scores submitted for them.");
        if (confirmed) { DbContext.Contestants.Remove(contestant); await DbContext.SaveChangesAsync(); await LoadContestants(); }
    }
}
