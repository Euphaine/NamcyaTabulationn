@page "/settings"
@using Microsoft.EntityFrameworkCore
@using NamcyaTabulation.Data
@using NamcyaTabulation.Models
@using NamcyaTabulation.Services
@inject AppDbContext DbContext
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager

<PageTitle>System Settings</PageTitle>

<div class="container mt-4 fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-panel p-4 p-md-5">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-white border-opacity-10">
                    <div class="icon-glass bg-white bg-opacity-25 rounded-circle p-3 me-4 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-sliders icon-gradient-blue fs-3"></i>
                    </div>
                    <div>
                        <h2 class="fw-bolder text-white mb-0" style="letter-spacing: -1px;">System Settings</h2>
                        <p class="text-white-50 mb-0">Configure global tabulation rules and behaviors</p>
                    </div>
                </div>

                @if (showSuccessMessage)
                {
                    <div class="alert bg-success bg-opacity-25 text-white border-0 alert-dismissible fade show mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i> Settings saved successfully!
                        <button type="button" class="btn-close btn-close-white" @onclick="() => showSuccessMessage = false"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert bg-danger bg-opacity-25 text-white border-0 alert-dismissible fade show mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                        <button type="button" class="btn-close btn-close-white" @onclick="() => errorMessage = null"></button>
                    </div>
                }

                @if (settings != null)
                {
                    <form @onsubmit="SaveSettings" @onsubmit:preventDefault="true">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="glass-panel p-3 bg-opacity-10 h-100 border-0">
                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input glass-input fs-5 mt-0" type="checkbox" role="switch" id="allowTiesSwitch" @bind="settings.AllowTies">
                                        <label class="form-check-label text-white fw-bold ms-2 mt-1" for="allowTiesSwitch">Allow Final Ties</label>
                                    </div>
                                    <small class="text-white-50 d-block">If disabled, the system will use average scores and alphabetical order to forcefully break all ties.</small>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="glass-panel p-3 bg-opacity-10 h-100 border-0">
                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input glass-input fs-5 mt-0" type="checkbox" role="switch" id="lockScoringSwitch" @bind="settings.LockScoring">
                                        <label class="form-check-label text-white fw-bold ms-2 mt-1" for="lockScoringSwitch">Lock All Scoring</label>
                                    </div>
                                    <small class="text-white-50 d-block">Instantly prevents all judges from submitting or editing any scores across all events.</small>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="glass-panel p-3 bg-opacity-10 border-0">
                                    <label class="form-label text-white-50 fw-bold text-uppercase small">Tie-Breaker Ranking Engine</label>
                                    <select class="form-select glass-input text-white" @bind="settings.RankingSystem">
                                        <option value="Standard" class="text-dark">Standard Competition (1, 2, 2, 4)</option>
                                        <option value="Dense" class="text-dark">Dense Ranking (1, 2, 2, 3)</option>
                                        <option value="Fractional" class="text-dark">Fractional Ranking (1, 2.5, 2.5, 4)</option>
                                    </select>
                                    <small class="text-white-50 mt-2 d-block">Determines how tied scores mathematically affect the sum of ranks algorithm.</small>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="glass-panel p-3 bg-opacity-10 border-0">
                                    <label class="form-label text-white-50 fw-bold text-uppercase small">Decimal Precision</label>
                                    <input type="number" class="form-control glass-input text-white" @bind="settings.DecimalPrecision" min="0" max="4" />
                                    <small class="text-white-50 mt-2 d-block">The number of decimal places used when calculating the final average scores (default is 2).</small>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top border-white border-opacity-10 text-end">
                            <button type="submit" class="btn liquid-btn px-5 py-3 rounded-pill fw-bolder">
                                <i class="bi bi-save me-2"></i> Save Settings
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-center text-white-50 py-5">
                        <div class="spinner-border text-info mb-3" role="status"></div>
                        <div>Loading settings...</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private SystemSetting? settings;
    private bool showSuccessMessage = false;
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        try
        {
            settings = await DbContext.SystemSettings.FirstOrDefaultAsync();
            if (settings == null)
            {
                settings = new SystemSetting();
                DbContext.SystemSettings.Add(settings);
                await DbContext.SaveChangesAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DB ERROR] {ex.Message}");
            errorMessage = "Database mismatch detected. The new 'RankingSystem' column is missing. Please close the app and fully delete your 'namcya.db' file.";
            settings = new SystemSetting(); // Fallback so the UI doesn't hang!
        }
    }

    private async Task SaveSettings()
    {
        if (settings != null)
        {
            try
            {
                DbContext.SystemSettings.Update(settings);
                await DbContext.SaveChangesAsync();
                showSuccessMessage = true;
                errorMessage = null;
                
                // Hide success message automatically after 3 seconds
                _ = Task.Delay(3000).ContinueWith(_ => 
                {
                    showSuccessMessage = false;
                    InvokeAsync(StateHasChanged);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[SAVE ERROR] {ex.Message}");
                errorMessage = "Could not save settings. Ensure your database is properly reset.";
            }
        }
    }
}
