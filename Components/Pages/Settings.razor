@page "/settings"
@using Microsoft.EntityFrameworkCore
@using NamcyaTabulation.Data
@using NamcyaTabulation.Models
@using NamcyaTabulation.Services
@inject AppDbContext DbContext
@inject OrganizerAuthService AuthService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>System Settings</PageTitle>

@if (AuthService.CurrentOrganizer != null)
{
    <div class="container-fluid mt-4 mb-5 fade-in">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-white" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);">System Settings</h2>
            <a href="/admin-panel" class="btn btn-sm liquid-btn text-white shadow-sm"><i class="bi bi-arrow-left"></i> Back to Hub</a>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="glass-panel overflow-hidden">
                    <div class="p-4 border-bottom border-white border-opacity-10">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-sliders me-2"></i> Global Configuration</h5>
                    </div>
                    <div class="p-4">
                        @if (showSuccess)
                        {
                            <div class="alert bg-success bg-opacity-25 text-white border-0 d-flex align-items-center mb-4">
                                <i class="bi bi-check-circle-fill me-2"></i> Settings saved successfully!
                            </div>
                        }

                        <form @onsubmit="SaveSettings" @onsubmit:preventDefault="true">
                            <div class="mb-4">
                                <div class="form-check form-switch fs-5 d-flex align-items-center">
                                    <input class="form-check-input glass-input me-3" type="checkbox" role="switch" id="allowTiesSwitch" @bind="settings.AllowTies" style="width: 3rem; height: 1.5rem; cursor: pointer;" />
                                    <label class="form-check-label text-white" for="allowTiesSwitch" style="cursor: pointer;">
                                        <strong>Allow Ties in Rankings</strong>
                                        <span class="d-block fs-6 text-white-50 mt-1">If enabled, contestants with the exact same Rank Sum and Average Score will receive the same placement. If disabled, alphabetical sorting will break the tie.</span>
                                    </label>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-5 pt-3 border-top border-white border-opacity-10">
                                <button type="submit" class="btn liquid-btn w-100 text-white fw-bold">Save Settings</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private SystemSetting settings = new();
    private bool showSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeSessionAsync();
        if (AuthService.CurrentOrganizer == null) { NavManager.NavigateTo("/"); return; }

        var existingSettings = await DbContext.SystemSettings.FirstOrDefaultAsync();
        if (existingSettings != null) { settings = existingSettings; }
    }

    private async Task SaveSettings()
    {
        if (settings.Id == 0) DbContext.SystemSettings.Add(settings);
        else DbContext.SystemSettings.Update(settings);

        await DbContext.SaveChangesAsync();
        
        showSuccess = true; StateHasChanged();
        await Task.Delay(3000); showSuccess = false; StateHasChanged();
    }
}